{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "abacus": {
      "name": "Abacus AI",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "route-llm": {
          "name": "Route LLM"
        }
      },
      "options": {
        "baseURL": "https://routellm.abacus.ai/v1/",
        "apiKey": "__ABACUS_API_KEY__"
      }
    }
  },
  "mcp": {
    "jcodemunch": {
      "type": "remote",
      "url": "http://localhost:8901/mcp",
      "enabled": true
    },
    "jdocmunch": {
      "type": "remote",
      "url": "http://localhost:8901/mcp",
      "enabled": true
    }
  },
  "agent": {
    "ask": {
      "mode": "primary",
      "prompt": "You have access to no tools, you can only respond to questions",
      "tools": {
        "*": false
      }
    }
  }
}
